# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
# Server-only read token (drafts/preview). Create in sanity.io/manage with Viewer role.
SANITY_API_READ_TOKEN=
# Server-only WRITE token (used by /api/inquiry to save submissions to Studio).
# Create in sanity.io/manage with "Editor" role; keep secret.
SANITY_API_WRITE_TOKEN=
# Used to authenticate revalidate webhook from Sanity (Phase 7).
SANITY_REVALIDATE_SECRET=

# Resend (Phase 6 \u2013 inquiry notification emails)
RESEND_API_KEY=
# Where new inquiries are emailed. Can be the client's address.
INQUIRY_TO_EMAIL=
# Optional: override the From address. Defaults to Resend's onboarding sandbox.
# In production, set this to a verified domain, e.g. "Tilal <noreply@tilal.com>".
INQUIRY_FROM_EMAIL=

# Public site URL (for metadata, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
